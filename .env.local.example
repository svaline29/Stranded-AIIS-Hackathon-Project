# Stranded — environment variable template
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to source control.

# ── Core LLM ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Voice (Layer 4+) ──────────────────────────────────────────────────────────
VAPI_API_KEY=
VAPI_PHONE_NUMBER_ID=
VAPI_WEBHOOK_SECRET=

# ── SMS fallback (Layer 5) ────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── Local tunnel (for Vapi webhooks during local dev) ─────────────────────────
NEXT_PUBLIC_TUNNEL_URL=
